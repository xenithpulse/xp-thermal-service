{
  "name": "xp-thermal-service",
  "version": "1.0.0",
  "description": "Production-grade local thermal printing service for restaurant POS",
  "main": "dist/index.js",
  "bin": {
    "xp-thermal": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "cli": "ts-node src/cli.ts",
    "service:install": "node dist/service/installer.js install",
    "service:uninstall": "node dist/service/installer.js uninstall",
    "service:start": "node dist/service/installer.js start",
    "service:stop": "node dist/service/installer.js stop",
    "test": "jest",
    "lint": "eslint src/**/*.ts"
  },
  "keywords": [
    "thermal-printer",
    "escpos",
    "pos",
    "receipt",
    "restaurant"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "commander": "^12.0.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "pino": "^8.18.0",
    "pino-pretty": "^10.3.1",
    "qrcode": "^1.5.3",
    "rate-limiter-flexible": "^5.0.0",
    "sql.js": "^1.10.0",
    "uuid": "^9.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.16",
    "@types/node-windows": "^0.1.6",
    "@types/qrcode": "^1.5.5",
    "@types/sql.js": "^1.4.10",
    "@types/uuid": "^9.0.8",
    "node-windows": "^1.0.0-beta.8",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
